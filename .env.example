APP_NAME="Top Burguer API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=top_burguer
DB_USERNAME=top_burguer
DB_PASSWORD=secret

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@topburguer.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Multi-tenancy: header (dev) ou subdomain (prod)
TENANT_IDENTIFICATION=header

# CORS: origens do frontend autorizadas
FRONTEND_URL=http://localhost:5173
